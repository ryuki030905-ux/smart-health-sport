# AI service example configuration
# Copy this file to `.env` for local development and fill in real values.

# LLM provider: openai / siliconflow / zhipu / ollama / custom
LLM_PROVIDER=custom

# API key for your model provider
LLM_API_KEY=your-api-key-here

# Model name exposed by your OpenAI-compatible endpoint
LLM_MODEL=gpt-4o-mini

# OpenAI-compatible base URL without trailing slash
LLM_BASE_URL=http://127.0.0.1:8787/codex/v1

# Optional model discovery and fallback behavior
LLM_AUTO_DETECT_MODELS=true
LLM_ENABLE_MODEL_FALLBACK=true

# Local embedding model for markdown knowledge retrieval
EMBED_MODEL=BAAI/bge-small-zh-v1.5

# RAG behavior
RAG_ENABLED=true
RAG_ALLOW_DEGRADED=true

# Debug output; keep false outside local development
DEBUG_VERBOSE=false

# Disable Chroma telemetry
ANONYMIZED_TELEMETRY=False

# FastAPI service port
PORT=8000

# Spring Boot backend base URL used by the AI service
SPRING_BOOT_BASE_URL=http://localhost:8080
